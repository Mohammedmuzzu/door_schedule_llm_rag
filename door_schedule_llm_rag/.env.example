# ═══════════════════════════════════════════════════════════════
#  Door Schedule LLM + RAG Extraction Pipeline
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Deployment Mode ──
# Set to "production" on Streamlit Cloud to hide Ollama option
DEPLOYMENT_ENV=local

# ── LLM Provider: "ollama", "groq", or "openai" ──
LLM_PROVIDER=openai

# ── OpenAI Settings ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Groq Settings ──
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama Settings (local only) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODELS=llama3.1:8b,mistral:7b
OLLAMA_TIMEOUT=180

# ── Extraction ──
MAX_PAGE_CHARS=16000

# ═══════════════════════════════════════════════════════════════
#  CLOUD / PRODUCTION SETTINGS (Supabase)
#  Leave blank for local development (uses SQLite + local files)
# ═══════════════════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ──
# Get from: Supabase Dashboard → Settings → Database → Connection String → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── File Storage (Supabase Storage / S3-compatible) ──
# Get from: Supabase Dashboard → Settings → Storage → S3 Connection
# AWS_ACCESS_KEY_ID=your-supabase-s3-access-key
# AWS_SECRET_ACCESS_KEY=your-supabase-s3-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=door-schedules
# S3_ENDPOINT_URL=https://[project-ref].supabase.co/storage/v1/s3
